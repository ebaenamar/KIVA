        {"start": 6.461624080882352, "end": 6.561649221453286, "text": "and"},
        {"start": 6.581654249567473, "end": 6.821714586937715, "text": "made"},
        {"start": 6.861724643166089, "end": 7.021764868079583, "text": "some"},
        {"start": 7.061774924307958, "end": 7.7219408520761235, "text": "chamomile"},
        {"start": 7.781955936418684, "end": 8.022016273788926, "text": "tea;"},
        {"start": 8.162051470588235, "end": 8.242071583044982, "text": "and"},
