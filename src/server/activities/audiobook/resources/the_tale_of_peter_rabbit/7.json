        {"start": 8.422116836072663, "end": 8.642172145328718, "text": "gave"},
        {"start": 8.662177173442906, "end": 8.682182201557092, "text": "a"},
        {"start": 8.76220231401384, "end": 9.022267679498269, "text": "dose"},
        {"start": 9.042272707612456, "end": 9.122292820069204, "text": "of"},
        {"start": 9.162302876297577, "end": 9.242322988754324, "text": "it"},
        {"start": 9.302338073096884, "end": 9.382358185553631, "text": "to"},
        {"start": 9.442373269896192, "end": 9.782458747837369, "text": "Peter!"},
        {"start": 10.942750378460206, "end": 11.182810715830449, "text": "\"One"},
        {"start": 11.242825800173009,
          "end": 12.043026924740483,
          "text": "table-spoonful"},
        {"start": 12.043026924740483, "end": 12.12304703719723, "text": "to"},
        {"start": 12.163057093425603, "end": 12.223072177768165, "text": "be"},
        {"start": 12.303092290224912, "end": 12.643177768166089, "text": "taken"},
        {"start": 12.683187824394462, "end": 12.783212964965395, "text": "at"},
        {"start": 12.843228049307957, "end": 13.463383920847749, "text": "bedtime.\""},
        {"start": 14.263585045415223, "end": 14.403620242214531, "text": "But"},
        {"start": 14.483640354671278, "end": 15.003771085640137, "text": "Flopsy,"},
        {"start": 15.163811310553632, "end": 15.603921929065741, "text": "Mopsy,"},
        {"start": 15.683942041522489, "end": 15.763962153979236, "text": "and"},
        {"start": 15.803972210207611,
          "end": 16.484143166089964,
          "text": "Cotton-tail"},
        {"start": 16.584168306660896, "end": 16.764213559688578, "text": "had"},
        {"start": 16.864238700259513, "end": 17.284344290657437, "text": "bread"},
        {"start": 17.364364403114184, "end": 17.46438954368512, "text": "and"},
        {"start": 17.504399599913494, "end": 17.824480049740483, "text": "milk"},
        {"start": 17.90450016219723, "end": 18.004525302768165, "text": "and"},
        {"start": 18.124555471453284,
          "end": 18.844736483564013,
          "text": "blackberries"},
        {"start": 18.92475659602076, "end": 19.04478676470588, "text": "for"},
        {"start": 19.124806877162627, "end": 19.444887326989615, "text": "supper."}
