      "text": [
        {"start": 0.480254498714653, "end": 0.5402863110539846, "text": "It"},
        {"start": 0.5402863110539846, "end": 0.6403393316195373, "text": "was"},
        {"start": 0.7003711439588689, "end": 0.7203817480719794, "text": "a"},
        {"start": 0.8004241645244216, "end": 1.0205408097686375, "text": "blue"},
        {"start": 1.1005832262210797, "end": 1.4807847043701798, "text": "jacket"},
        {"start": 1.5408165167095116, "end": 1.6808907455012854, "text": "with"},
        {"start": 1.740922557840617, "end": 2.1011134318766067, "text": "brass"},
        {"start": 2.2211770565552698, "end": 2.661410347043702, "text": "buttons,"},
        {"start": 2.7614633676092546, "end": 3.121654241645244, "text": "quite"},
        {"start": 3.221707262210797, "end": 3.4218133033419025, "text": "new."},
        {"start": 4.42234350899743, "end": 4.642460154241645, "text": "Peter"},
        {"start": 4.702491966580977, "end": 4.842566195372751, "text": "gave"},
        {"start": 4.862576799485861, "end": 5.222767673521851, "text": "himself"},
        {"start": 5.282799485861182, "end": 5.382852506426735, "text": "up"},
        {"start": 5.442884318766067, "end": 5.56294794344473, "text": "for"},
        {"start": 5.683011568123393, "end": 6.143255462724936, "text": "lost,"},
        {"start": 6.203287275064267, "end": 6.30334029562982, "text": "and"},
        {"start": 6.383382712082262, "end": 6.603499357326478, "text": "shed"},
        {"start": 6.68354177377892, "end": 6.863637210796915, "text": "big"},
        {"start": 6.983700835475578, "end": 7.503976542416452, "text": "tears;"},
        {"start": 7.584018958868895, "end": 7.7040825835475575, "text": "but"},
        {"start": 7.724093187660668, "end": 7.844156812339332, "text": "his"},
        {"start": 7.9442098329048845, "end": 8.364432519280205, "text": "sobs"},
        {"start": 8.404453727506427, "end": 8.564538560411311, "text": "were"},
        {"start": 8.604559768637532, "end": 9.084814267352185, "text": "overheard"},
        {"start": 9.144846079691517, "end": 9.26490970437018, "text": "by"},
        {"start": 9.324941516709512, "end": 9.485026349614396, "text": "some"},
        {"start": 9.525047557840617, "end": 9.885238431876607, "text": "friendly"},
        {"start": 10.02531266066838, "end": 10.585609575835475, "text": "sparrows,"},
        {"start": 11.12589588688946, "end": 11.225948907455013, "text": "who"},
        {"start": 11.326001928020565, "end": 11.546118573264781, "text": "flew"},
        {"start": 11.586139781491003, "end": 11.646171593830333, "text": "to"},
        {"start": 11.706203406169665, "end": 11.806256426735219, "text": "him"},
        {"start": 11.86628823907455, "end": 11.926320051413882, "text": "in"},
        {"start": 12.006362467866325, "end": 12.26650032133676, "text": "great"},
        {"start": 12.306521529562982, "end": 12.966871465295629, "text": "excitement,"},
        {"start": 13.00689267352185, "end": 13.106945694087404, "text": "and"},
        {"start": 13.146966902313624, "end": 13.6672426092545, "text": "implored"},
        {"start": 13.707263817480719, "end": 13.827327442159383, "text": "him"},
        {"start": 13.867348650385605, "end": 13.927380462724935, "text": "to"},
        {"start": 14.027433483290489, "end": 14.407634961439589, "text": "exert"},
        {"start": 14.4276455655527, "end": 14.887889460154241, "text": "himself."},
        {"start": 15.728334832904885, "end": 15.98847268637532, "text": "Mr"},
        {"start": 16.00848329048843, "end": 16.408695372750643, "text": "McGregor"},
        {"start": 16.488737789203086, "end": 16.7088544344473, "text": "came"},
        {"start": 16.72886503856041, "end": 16.828918059125964, "text": "up"},
        {"start": 16.888949871465297, "end": 17.029024100257068, "text": "with"},
        {"start": 17.06904530848329, "end": 17.0890559125964, "text": "a"},
        {"start": 17.209119537275065, "end": 17.48926799485861, "text": "sieve,"},
        {"start": 17.529289203084833, "end": 17.709384640102826, "text": "which"},
        {"start": 17.729395244215937, "end": 17.78942705655527, "text": "he"},
        {"start": 17.82944826478149, "end": 18.2296603470437, "text": "intended"},
        {"start": 18.269681555269923, "end": 18.329713367609255, "text": "to"},
        {"start": 18.389745179948587, "end": 18.669893637532134, "text": "pop"},
        {"start": 18.80996786632391, "end": 19.090116323907456, "text": "upon"},
        {"start": 19.150148136246788, "end": 19.250201156812338, "text": "the"},
        {"start": 19.35025417737789, "end": 19.570370822622106, "text": "top"},
        {"start": 19.63040263496144, "end": 19.71044505141388, "text": "of"},
        {"start": 19.810498071979435, "end": 20.110657133676092, "text": "Peter;"},
        {"start": 20.250731362467867, "end": 20.39080559125964, "text": "but"},
        {"start": 20.43082679948586, "end": 20.710975257069407, "text": "Peter"},
        {"start": 20.77100706940874, "end": 21.111187339331618, "text": "wriggled"},
        {"start": 21.21124035989717, "end": 21.371325192802058, "text": "out"},
        {"start": 21.451367609254497, "end": 21.691494858611826, "text": "just"},
        {"start": 21.751526670951158, "end": 21.831569087403597, "text": "in"},
        {"start": 21.89160089974293, "end": 22.23178116966581, "text": "time,"},
        {"start": 22.27180237789203, "end": 22.551950835475576, "text": "leaving"},
        {"start": 22.571961439588687, "end": 22.69202506426735, "text": "his"},
        {"start": 22.772067480719794, "end": 23.132258354755784, "text": "jacket"},
        {"start": 23.172279562982006, "end": 23.63252345758355, "text": "behind"},
        {"start": 23.672544665809767, "end": 23.812618894601542, "text": "him,"},
        {"start": 24.51299003856041, "end": 24.653064267352185, "text": "and"},
        {"start": 24.793138496143957, "end": 25.13331876606684, "text": "rushed"},
        {"start": 25.173339974293057, "end": 25.333424807197943, "text": "into"},
        {"start": 25.373446015424165, "end": 25.453488431876607, "text": "the"},
        {"start": 25.51352024421594, "end": 26.173870179948587, "text": "tool-shed,"},
        {"start": 26.213891388174808, "end": 26.31394440874036, "text": "and"},
        {"start": 26.3939868251928, "end": 26.69414588688946, "text": "jumped"},
        {"start": 26.75417769922879, "end": 26.934273136246787, "text": "into"},
        {"start": 27.014315552699227, "end": 27.034326156812337, "text": "a"},
        {"start": 27.11436857326478, "end": 27.49457005141388, "text": "can."},
        {"start": 28.134909383033417, "end": 28.19494119537275, "text": "It"},
        {"start": 28.23496240359897, "end": 28.375036632390746, "text": "would"},
        {"start": 28.395047236503856, "end": 28.515110861182517, "text": "have"},
        {"start": 28.515110861182517, "end": 28.655185089974292, "text": "been"},
        {"start": 28.675195694087403, "end": 28.695206298200514, "text": "a"},
        {"start": 28.755238110539846, "end": 29.155450192802057, "text": "beautiful"},
        {"start": 29.21548200514139, "end": 29.37556683804627, "text": "thing"},
        {"start": 29.415588046272493, "end": 29.495630462724936, "text": "to"},
        {"start": 29.59568348329049, "end": 29.95587435732648, "text": "hide"},
        {"start": 29.97588496143959, "end": 30.07593798200514, "text": "in,"},
        {"start": 30.135969794344472, "end": 30.216012210796915, "text": "if"},
        {"start": 30.276044023136247, "end": 30.35608643958869, "text": "it"},
        {"start": 30.396107647814908, "end": 30.516171272493573, "text": "had"},
        {"start": 30.596213688946015, "end": 30.83634093830334, "text": "not"},
        {"start": 30.916383354755784, "end": 31.136499999999998, "text": "had"},
        {"start": 31.21654241645244, "end": 31.316595437017995, "text": "so"},
        {"start": 31.396637853470438, "end": 31.59674389460154, "text": "much"},
        {"start": 31.716807519280206, "end": 32.056987789203085, "text": "water"},
        {"start": 32.13703020565553, "end": 32.21707262210797, "text": "in"},
        {"start": 32.25709383033419, "end": 32.357146850899746, "text": "it."},
        {"start": 33.21760282776349, "end": 33.49775128534704, "text": "Mr"},
        {"start": 33.537772493573264, "end": 33.95799517994858, "text": "McGregor"},
        {"start": 34.038037596401026, "end": 34.15810122107969, "text": "was"},
        {"start": 34.23814363753213, "end": 34.598334511568126, "text": "quite"},
        {"start": 34.63835571979435, "end": 34.85847236503856, "text": "sure"},
        {"start": 34.89849357326478, "end": 35.018557197943444, "text": "that"},
        {"start": 35.058578406169666, "end": 35.338726863753216, "text": "Peter"},
        {"start": 35.37874807197944, "end": 35.498811696658095, "text": "was"},
        {"start": 35.59886471722365, "end": 36.019087403598974, "text": "somewhere"},
        {"start": 36.039098007712084, "end": 36.09912982005142, "text": "in"},
        {"start": 36.11914042416453, "end": 36.19918284061696, "text": "the"},
        {"start": 36.239204048843185, "end": 36.819511568123396, "text": "tool-shed,"},
        {"start": 37.2197236503856, "end": 37.65995694087403, "text": "perhaps"},
        {"start": 37.719988753213364, "end": 37.94010539845758, "text": "hidden"},
        {"start": 37.980126606683804, "end": 38.320306876606686, "text": "underneath"},
        {"start": 38.36032808483291, "end": 38.38033868894601, "text": "a"},
        {"start": 38.38033868894601, "end": 39.14074164524421, "text": "flower-pot."},
        {"start": 39.72104916452442, "end": 39.801091580976866, "text": "He"},
        {"start": 39.8611233933162, "end": 40.241324871465295, "text": "began"},
        {"start": 40.30135668380463, "end": 40.36138849614396, "text": "to"},
        {"start": 40.4414309125964, "end": 40.741589974293056, "text": "turn"},
        {"start": 40.78161118251928, "end": 40.90167480719794, "text": "them"},
        {"start": 41.02173843187661, "end": 41.32189749357327, "text": "over"},
        {"start": 41.50199293059126, "end": 42.04227924164525, "text": "carefully,"},
        {"start": 42.24238528277635, "end": 42.54254434447301, "text": "looking"},
        {"start": 42.60257615681234, "end": 42.84270340616967, "text": "under"},
        {"start": 42.942756426735215, "end": 43.202894280205655, "text": "each."},
        {"start": 44.00331844473008, "end": 44.56361535989717, "text": "Presently"},
        {"start": 44.64365777634961, "end": 44.90379562982005, "text": "Peter"},
        {"start": 44.963827442159385, "end": 46.30453791773779, "text": "sneezed—\"Kerchoo!\""}
      ]
    }
  ]
}
