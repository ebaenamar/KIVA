        {"start": 5.601989247311828, "end": 5.782053187403994, "text": "some"},
        {"start": 5.8820887096774195, "end": 6.542323156682028, "text": "radishes;"},
        {"start": 7.442642857142857, "end": 7.542678379416283, "text": "And"},
        {"start": 7.562685483870967, "end": 7.702735215053764, "text": "then,"},
