        {"start": 43.21534562211981, "end": 43.43542377112135, "text": "might"},
        {"start": 43.455430875576035, "end": 43.57547350230415, "text": "have"},
        {"start": 43.595480606758834, "end": 43.775544546851, "text": "got"},
        {"start": 43.89558717357911, "end": 44.11566532258065, "text": "away"},
        {"start": 44.21570084485407, "end": 44.795906874039936, "text": "altogether"},
        {"start": 44.87593529185868, "end": 44.95596370967742, "text": "if"},
        {"start": 44.99597791858679, "end": 45.05599923195084, "text": "he"},
        {"start": 45.09601344086021, "end": 45.216056067588326, "text": "had"},
        {"start": 45.27607738095238, "end": 45.45614132104455, "text": "not,"},
        {"start": 45.576183947772655, "end": 46.51651785714286, "text": "unfortunately,"},
        {"start": 47.136738095238094, "end": 47.35681624423963, "text": "run"},
        {"start": 47.416837557603685, "end": 47.59690149769585, "text": "into"},
        {"start": 47.67692991551459, "end": 47.696937019969276, "text": "a"},
        {"start": 47.77696543778802, "end": 48.37717857142857, "text": "gooseberry"},
        {"start": 48.45720698924731, "end": 48.67728513824885, "text": "net,"},
        {"start": 49.15745564516129, "end": 49.257491167434715, "text": "and"},
        {"start": 49.31751248079877, "end": 49.47756931643625, "text": "got"},
        {"start": 49.55759773425499, "end": 49.857704301075266, "text": "caught"},
        {"start": 49.91772561443933, "end": 50.01776113671275, "text": "by"},
        {"start": 50.037768241167434, "end": 50.13780376344086, "text": "the"},
        {"start": 50.2178321812596, "end": 50.6179742703533, "text": "large"},
        {"start": 50.698002688172046, "end": 51.07813767281106, "text": "buttons"},
        {"start": 51.1581660906298, "end": 51.238194508448544, "text": "on"},
        {"start": 51.25820161290323, "end": 51.39825134408602, "text": "his"},
        {"start": 51.558308179723504, "end": 51.97845737327189, "text": "jacket."}
      ]
