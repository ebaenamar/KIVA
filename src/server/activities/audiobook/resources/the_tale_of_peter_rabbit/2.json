        {"start": 37.95347715053764, "end": 38.033505568356375, "text": "the"},
        {"start": 38.05351267281106, "end": 38.69374001536098, "text": "potatoes."},
        {"start": 39.23393183563748, "end": 39.494024193548384, "text": "After"},
        {"start": 39.53403840245776, "end": 39.874159178187405, "text": "losing"},
        {"start": 39.89416628264209, "end": 40.0142089093702, "text": "them,"},
        {"start": 40.05422311827957, "end": 40.09423732718894, "text": "he"},
        {"start": 40.17426574500768, "end": 40.35432968509985, "text": "ran"},
        {"start": 40.43435810291859, "end": 40.53439362519201, "text": "on"},
        {"start": 40.614422043010755, "end": 40.8144930875576, "text": "four"},
        {"start": 40.87451440092166, "end": 41.23464228110599, "text": "legs"},
        {"start": 41.254649385560676, "end": 41.334677803379414, "text": "and"},
