        {"start": 32.15141685867896, "end": 32.31147369431643, "text": "way"},
        {"start": 32.39150211213518, "end": 32.611580261136716, "text": "back"},
        {"start": 32.691608678955454, "end": 32.77163709677419, "text": "to"},
        {"start": 32.81165130568356, "end": 32.91168682795699, "text": "the"},
        {"start": 32.95170103686636, "end": 33.251807603686636, "text": "gate."},
        {"start": 34.29217703533026, "end": 34.352198348694316, "text": "He"},
        {"start": 34.492248079877115, "end": 34.852375960061444, "text": "lost"},
        {"start": 34.95241148233487, "end": 35.07245410906298, "text": "one"},
        {"start": 35.07245410906298, "end": 35.15248252688172, "text": "of"},
        {"start": 35.172489631336404, "end": 35.29253225806452, "text": "his"},
        {"start": 35.37256067588326, "end": 35.7126814516129, "text": "shoes"},
        {"start": 35.772702764976955, "end": 36.01278801843318, "text": "among"},
        {"start": 36.03279512288786, "end": 36.11282354070661, "text": "the"},
        {"start": 36.152837749615976, "end": 36.833079301075266, "text": "cabbages,"},
        {"start": 36.91310771889401, "end": 37.013143241167434, "text": "and"},
        {"start": 37.0531574500768, "end": 37.13318586789555, "text": "the"},
