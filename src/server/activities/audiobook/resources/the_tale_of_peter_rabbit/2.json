        {"start": 12.224340821812596, "end": 12.304369239631336, "text": "of"},
        {"start": 12.344383448540707, "end": 12.364390552995392, "text": "a"},
        {"start": 12.424411866359447, "end": 12.94459658218126, "text": "cucumber"},
        {"start": 13.024625, "end": 13.384752880184331, "text": "frame,"},
        {"start": 13.504795506912442, "end": 13.844916282642089, "text": "whom"},
