        {"start": 8.923168586789554, "end": 9.003197004608294, "text": "he"},
        {"start": 9.083225422427036, "end": 9.243282258064516, "text": "went"},
        {"start": 9.283296466973887, "end": 9.34331778033794, "text": "to"},
