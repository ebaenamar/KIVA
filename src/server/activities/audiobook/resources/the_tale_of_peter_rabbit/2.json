        {"start": 21.80774385560676, "end": 21.92778648233487, "text": "but"},
        {"start": 21.96780069124424, "end": 22.00781490015361, "text": "he"},
        {"start": 22.12785752688172, "end": 22.427964093702, "text": "jumped"},
        {"start": 22.467978302611368, "end": 22.58802092933948, "text": "up"},
        {"start": 22.628035138248848, "end": 22.74807776497696, "text": "and"},
        {"start": 22.848113287250385, "end": 23.10820564516129, "text": "ran"},
        {"start": 23.18823406298003, "end": 23.42831931643625, "text": "after"},
        {"start": 23.48834062980031, "end": 23.788447196620584, "text": "Peter,"},
        {"start": 23.88848271889401, "end": 24.24861059907834, "text": "waving"},
        {"start": 24.288624807987713, "end": 24.308631912442397, "text": "a"},
        {"start": 24.388660330261136, "end": 24.648752688172042, "text": "rake"},
        {"start": 24.648752688172042, "end": 24.768795314900153, "text": "and"},
        {"start": 24.808809523809522, "end": 25.18894450844854, "text": "calling"},
        {"start": 25.26897292626728, "end": 25.46904397081413, "text": "out,"},
        {"start": 25.689122119815668, "end": 26.04925, "text": "\"Stop"},
        {"start": 26.269328149001534, "end": 26.54942761136713, "text": "thief!\""},
        {"start": 27.76986098310292, "end": 28.109981758832564, "text": "Peter"},
        {"start": 28.149995967741937, "end": 28.290045698924732, "text": "was"},
