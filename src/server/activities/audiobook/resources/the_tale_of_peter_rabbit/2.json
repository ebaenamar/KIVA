        {"start": 29.210372503840247, "end": 29.670535906298003, "text": "frightened;"},
        {"start": 29.710550115207372, "end": 29.790578533026114, "text": "he"},
        {"start": 29.89061405529954, "end": 30.17071351766513, "text": "rushed"},
        {"start": 30.270749039938558, "end": 30.410798771121353, "text": "all"},
        {"start": 30.450812980030722, "end": 30.610869815668202, "text": "over"},
        {"start": 30.630876920122887, "end": 30.71090533794163, "text": "the"},
        {"start": 30.770926651305682, "end": 31.1510616359447, "text": "garden,"},
        {"start": 31.23109005376344, "end": 31.331125576036868, "text": "for"},
        {"start": 31.371139784946237, "end": 31.43116109831029, "text": "he"},
        {"start": 31.451168202764975, "end": 31.511189516129033, "text": "had"},
