        {"start": 14.665207565284177, "end": 14.865278609831028, "text": "but"},
        {"start": 15.10536386328725, "end": 15.525513056835637, "text": "Mr"},
        {"start": 15.585534370199692, "end": 16.12572619047619, "text": "McGregor!"},
        {"start": 17.126081413210446, "end": 17.406180875576037, "text": "Mr"},
        {"start": 17.426187980030722, "end": 17.84633717357911, "text": "McGregor"},
        {"start": 17.906358486943166, "end": 18.04640821812596, "text": "was"},
        {"start": 18.146443740399384, "end": 18.266486367127495, "text": "on"},
        {"start": 18.28649347158218, "end": 18.42654320276498, "text": "his"},
        {"start": 18.506571620583717, "end": 18.926720814132103, "text": "hands"},
        {"start": 18.966735023041476, "end": 19.046763440860214, "text": "and"},
