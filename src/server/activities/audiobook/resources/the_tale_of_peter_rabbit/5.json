      "text": [
        {"start": 0.2000459838002025, "end": 0.3000689757003038, "text": "She"},
        {"start": 0.4200965659804252, "end": 0.640147148160648, "text": "only"},
        {"start": 0.7801793368207898, "end": 0.960220722240972, "text": "shook"},
        {"start": 1.0202345173810328, "end": 1.1002529109011137, "text": "her"},
        {"start": 1.1802713044211948, "end": 1.3603126898413769, "text": "head"},
        {"start": 1.4003218866014175, "end": 1.5003448785015188, "text": "at"},
        {"start": 1.520349476881539, "end": 1.6803862639217009, "text": "him."},
        {"start": 2.42055640398245, "end": 2.740629978062774, "text": "Peter"},
        {"start": 2.800643773202835, "end": 3.120717347283159, "text": "began"},
        {"start": 3.1807311424232196, "end": 3.2407449375632806, "text": "to"},
        {"start": 3.3207633310833615, "end": 3.7408598970637867, "text": "cry."},
        {"start": 4.881122004724941, "end": 5.021154193385082, "text": "Then"},
        {"start": 5.041158791765103, "end": 5.101172586905164, "text": "he"},
        {"start": 5.161186382045225, "end": 5.421246160985488, "text": "tried"},
        {"start": 5.461255357745528, "end": 5.5012645545055685, "text": "to"},
        {"start": 5.5612783496456295, "end": 5.841342726965913, "text": "find"},
        {"start": 5.861347325345934, "end": 5.961370317246034, "text": "his"},
        {"start": 6.061393309146136, "end": 6.241434694566318, "text": "way"},
        {"start": 6.441480678366521, "end": 6.8415726459669255, "text": "straight"},
        {"start": 6.921591039487007, "end": 7.321683007087412, "text": "across"},
        {"start": 7.381696802227472, "end": 7.4817197941275735, "text": "the"},
        {"start": 7.521728990887614, "end": 7.921820958488019, "text": "garden,"},
        {"start": 8.02184395038812, "end": 8.141871540668241, "text": "but"},
        {"start": 8.161876139048262, "end": 8.221889934188322, "text": "he"},
        {"start": 8.261899130948363, "end": 8.661991098548768, "text": "became"},
        {"start": 8.74200949206885, "end": 9.042078467769153, "text": "more"},
        {"start": 9.082087664529194, "end": 9.182110656429295, "text": "and"},
        {"start": 9.222119853189335, "end": 9.422165836989537, "text": "more"},
        {"start": 9.502184230509618, "end": 10.122326780290246, "text": "puzzled."},
        {"start": 10.762473928450895, "end": 11.302598084711441, "text": "Presently,"},
        {"start": 11.342607281471482, "end": 11.402621076611542, "text": "he"},
        {"start": 11.462634871751604, "end": 11.702690052311846, "text": "came"},
        {"start": 11.722694650691867, "end": 11.782708445831927, "text": "to"},
        {"start": 11.862726839352009, "end": 11.882731437732028, "text": "a"},
        {"start": 11.96274983125211, "end": 12.422855593992574, "text": "pond"},
        {"start": 12.502873987512656, "end": 12.662910774552818, "text": "where"},
        {"start": 12.682915372932838, "end": 12.962979750253123, "text": "Mr"},
        {"start": 12.982984348633142, "end": 13.463094709753628, "text": "McGregor"},
        {"start": 13.523108504893688, "end": 13.803172882213973, "text": "filled"},
        {"start": 13.823177480593992, "end": 13.923200472494093, "text": "his"},
        {"start": 14.023223464394196,
          "end": 14.863416596355046,
          "text": "water-cans."},
        {"start": 15.643595933175835, "end": 15.663600531555856, "text": "A"},
        {"start": 15.803632720215997, "end": 16.08369709753628, "text": "white"},
        {"start": 16.16371549105636, "end": 16.463784466756664, "text": "cat"},
        {"start": 16.523798261896726, "end": 16.643825852176846, "text": "was"},
        {"start": 16.74384884407695, "end": 17.223959205197435, "text": "staring"},
        {"start": 17.263968401957477, "end": 17.343986795477555, "text": "at"},
        {"start": 17.404000590617617, "end": 17.5840419760378, "text": "some"},
        {"start": 17.62405117279784, "end": 18.284202919338508, "text": "goldfish."},
        {"start": 18.904345469119136, "end": 19.004368461019236, "text": "She"},
        {"start": 19.1644052480594, "end": 19.3644512318596, "text": "sat"},
        {"start": 19.524488018899763, "end": 19.92457998650017, "text": "very,"},
        {"start": 20.04460757678029, "end": 20.324671954100573, "text": "very"},
        {"start": 20.504713339520755, "end": 20.884800708741142, "text": "still,"},
        {"start": 21.50494325852177, "end": 21.64497544718191, "text": "but"},
        {"start": 21.785007635842053, "end": 22.105081209922375, "text": "now"},
        {"start": 22.185099603442456, "end": 22.30512719372258, "text": "and"},
        {"start": 22.36514098886264, "end": 22.54518237428282, "text": "then"},
        {"start": 22.605196169422882, "end": 22.685214562942964, "text": "the"},
        {"start": 22.765232956463045, "end": 22.945274341883227, "text": "tip"},
        {"start": 23.00528813702329, "end": 23.085306530543367, "text": "of"},
        {"start": 23.12531572730341, "end": 23.22533871920351, "text": "her"},
        {"start": 23.30535711272359, "end": 23.645435285183936, "text": "tail"},
        {"start": 23.8054720722241, "end": 24.285582433344583, "text": "twitched"},
        {"start": 24.365600826864664, "end": 24.465623818764765, "text": "as"},
        {"start": 24.525637613904827, "end": 24.60565600742491, "text": "if"},
        {"start": 24.665669802564967, "end": 24.72568359770503, "text": "it"},
        {"start": 24.765692794465068, "end": 24.92572958150523, "text": "were"},
        {"start": 24.965738778265273, "end": 25.60588592642592, "text": "alive."},
        {"start": 26.40606986162673, "end": 26.706138837327032, "text": "Peter"},
        {"start": 26.786157230847113, "end": 27.006207813027338, "text": "thought"},
        {"start": 27.046217009787377, "end": 27.126235403307458, "text": "it"},
        {"start": 27.22625839520756, "end": 27.486318174147822, "text": "best"},
        {"start": 27.526327370907865, "end": 27.586341166047923, "text": "to"},
        {"start": 27.646354961187985, "end": 27.726373354708066, "text": "go"},
        {"start": 27.846400944988186, "end": 28.146469920688492, "text": "away"},
        {"start": 28.226488314208574, "end": 28.56656648666892, "text": "without"},
        {"start": 28.646584880188996, "end": 29.046676847789403, "text": "speaking"},
        {"start": 29.066681446169422, "end": 29.126695241309484, "text": "to"},
        {"start": 29.206713634829566, "end": 29.406759618629767, "text": "her;"},
        {"start": 30.166934357070538, "end": 30.24695275059062, "text": "he"},
        {"start": 30.26695734897064, "end": 30.36698034087074, "text": "had"},
        {"start": 30.46700333277084, "end": 30.727063111711104, "text": "heard"},
        {"start": 30.767072308471143, "end": 31.027132087411406, "text": "about"},
        {"start": 31.107150480931487, "end": 31.447228653391832, "text": "cats"},
        {"start": 31.507242448531894, "end": 31.667279235572057, "text": "from"},
        {"start": 31.687283833952076, "end": 31.827316022612216, "text": "his"},
        {"start": 31.92733901451232, "end": 32.307426383732704, "text": "cousin,"},
        {"start": 32.40744937563281, "end": 32.62749995781303, "text": "little"},
        {"start": 32.68751375295309, "end": 33.147619515693556, "text": "Benjamin"},
        {"start": 33.227637909213634, "end": 33.4876976881539, "text": "Bunny."},
        {"start": 34.38790461525481, "end": 34.46792300877489, "text": "He"},
        {"start": 34.56794600067499, "end": 34.767991984475195, "text": "went"},
        {"start": 34.84801037799527, "end": 35.08806555855552, "text": "back"},
        {"start": 35.14807935369558, "end": 35.54817132129598, "text": "towards"},
        {"start": 35.60818511643605, "end": 35.708208108336144, "text": "the"},
        {"start": 35.76822190347621, "end": 36.42837365001687, "text": "tool-shed,"},
        {"start": 36.48838744515694, "end": 36.628419633817074, "text": "but"},
        {"start": 36.7484472240972, "end": 37.1485391916976, "text": "suddenly,"},
        {"start": 37.248562183597706, "end": 37.52862656091799, "text": "quite"},
        {"start": 37.54863115929801, "end": 37.888709331758356, "text": "close"},
        {"start": 37.908713930138376, "end": 37.98873232365845, "text": "to"},
        {"start": 38.02874152041849, "end": 38.1287645123186, "text": "him,"},
        {"start": 38.168773709078636, "end": 38.228787504218694, "text": "he"},
        {"start": 38.28880129935876, "end": 38.48884728315896, "text": "heard"},
        {"start": 38.50885188153898, "end": 38.608874873439085, "text": "the"},
        {"start": 38.648884070199124, "end": 39.04897603779953, "text": "noise"},
        {"start": 39.088985234559566, "end": 39.14899902969963, "text": "of"},
        {"start": 39.20901282483969, "end": 39.22901742321971, "text": "a"},
        {"start": 39.34904501349983,
          "end": 40.649343908201146,
          "text": "hoe—scr-r-ritch,"},
        {"start": 40.78937609686129, "end": 41.24948185960176, "text": "scratch,"},
        {"start": 41.349504851501855, "end": 41.809610614242324, "text": "scratch,"},
        {"start": 41.92963820452244, "end": 42.32973017212285, "text": "scritch."},
        {"start": 43.469992279784, "end": 43.81007045224435, "text": "Peter"},
        {"start": 43.99011183766453, "end": 44.37019920688491, "text": "scuttered"},
        {"start": 44.41020840364495, "end": 44.81030037124536, "text": "underneath"},
        {"start": 44.83030496962538, "end": 44.93032796152548, "text": "the"},
        {"start": 44.970337158285524, "end": 45.39043372426595, "text": "bushes."},
        {"start": 45.99057167566655, "end": 46.130603864326694, "text": "But"},
        {"start": 46.21062225784678, "end": 46.71073721734729, "text": "presently,"},
        {"start": 46.790755610867365, "end": 46.87077400438744, "text": "as"},
        {"start": 46.95079239790753, "end": 47.25086137360783, "text": "nothing"},
        {"start": 47.29087057036787, "end": 47.670957939588256, "text": "happened,"},
        {"start": 47.690962537968275, "end": 47.75097633310833, "text": "he"},
        {"start": 47.83099472662842, "end": 48.09105450556868, "text": "came"},
        {"start": 48.131063702328724, "end": 48.29110048936888, "text": "out,"},
        {"start": 48.331109686128926, "end": 48.43113267802902, "text": "and"},
        {"start": 48.47114187478906, "end": 48.89123844076949, "text": "climbed"},
        {"start": 48.93124763752953, "end": 49.17130281808977, "text": "upon"},
        {"start": 49.231316613229836, "end": 49.251321211609856, "text": "a"},
        {"start": 49.33133960512993,
          "end": 49.891468359770506,
          "text": "wheelbarrow,"},
        {"start": 50.35157412251097, "end": 50.47160171279109, "text": "and"},
        {"start": 50.53161550793115, "end": 50.811679885251436, "text": "peeped"},
        {"start": 50.891698278771514, "end": 51.1717626560918, "text": "over."},
        {"start": 51.91193279615255, "end": 52.01195578805265, "text": "The"},
        {"start": 52.09197418157273, "end": 52.39204315727304, "text": "first"},
        {"start": 52.432052354033075, "end": 52.61209373945326, "text": "thing"},
        {"start": 52.63209833783328, "end": 52.692112132973335, "text": "he"},
        {"start": 52.81213972325346, "end": 53.01218570705366, "text": "saw"},
        {"start": 53.112208698953765, "end": 53.25224088761391, "text": "was"},
        {"start": 53.332259281133986, "end": 53.63232825683429, "text": "Mr"},
        {"start": 53.67233745359433, "end": 54.17245241309484, "text": "McGregor"},
        {"start": 54.292480003374955, "end": 54.61255357745528, "text": "hoeing"},
        {"start": 54.692571970975365, "end": 55.15267773371583, "text": "onions."},
        {"start": 55.75281568511644, "end": 55.93285707053662, "text": "His"},
        {"start": 56.03288006243672, "end": 56.272935242996965, "text": "back"},
        {"start": 56.35295363651704, "end": 56.492985825177186, "text": "was"},
        {"start": 56.552999620317244, "end": 56.83306399763753, "text": "turned"},
        {"start": 56.85306859601755, "end": 57.173142170097876, "text": "towards"},
        {"start": 57.233155965237934, "end": 57.51322034255822, "text": "Peter,"},
        {"start": 57.5932387360783, "end": 57.6932617279784, "text": "and"},
        {"start": 57.73327092473844, "end": 58.23338588423895, "text": "beyond"},
        {"start": 58.29339967937901, "end": 58.43343186803915, "text": "him"},
        {"start": 58.49344566317921, "end": 58.61347325345933, "text": "was"},
        {"start": 58.69349164697941, "end": 58.773510040499495, "text": "the"},
        {"start": 58.833523835639554, "end": 59.15359740971988, "text": "gate!"}
      ]
    }
  ]
}
