      "text": [
        {"start": 3.1412474082256967, "end": 3.30131097042828, "text": "Once"},
        {"start": 3.321318915703603, "end": 3.521398368456832, "text": "upon"},
        {"start": 3.5614142590074778, "end": 3.581422204282801, "text": "a"},
        {"start": 3.6614539853840924, "end": 3.981581109789259, "text": "time"},
        {"start": 4.021597000339905, "end": 4.141644671991842, "text": "there"},
        {"start": 4.1616526172671655, "end": 4.301708234194425, "text": "were"},
        {"start": 4.381740015295717, "end": 4.661851249150238, "text": "four"},
        {"start": 4.901946592454113, "end": 5.122033990482665, "text": "little"},
        {"start": 5.162049881033311, "end": 5.6022246770904145, "text": "Rabbits,"},
        {"start": 5.6822564581917065, "end": 5.762288239292998, "text": "and"},
        {"start": 5.782296184568321, "end": 5.902343856220258, "text": "their"},
        {"start": 5.922351801495581, "end": 6.382534542828008, "text": "names"},
        {"start": 6.4625663239293, "end": 6.642637831407206, "text": "were—"},
        {"start": 6.762685503059143, "end": 7.282892080217539, "text": "Flopsy,"},
        {"start": 7.482971532970768, "end": 7.9231463290278725, "text": "Mopsy,"},
        {"start": 8.123225781781102, "end": 8.903535647518694, "text": "Cotton-tail,"},
        {"start": 9.023583319170632, "end": 9.123623045547246, "text": "and"},
        {"start": 9.203654826648538, "end": 9.523781951053705, "text": "Peter."},
        {"start": 10.524179214819851, "end": 10.624218941196466, "text": "They"},
        {"start": 10.684242777022433, "end": 10.904330175050985, "text": "lived"},
        {"start": 10.944346065601632, "end": 11.044385791978247, "text": "with"},
        {"start": 11.06439373725357, "end": 11.164433463630184, "text": "their"},
        {"start": 11.264473190006798, "end": 11.544584423861318, "text": "Mother"},
        {"start": 11.62461620496261, "end": 11.704647986063902, "text": "in"},
        {"start": 11.744663876614547, "end": 11.764671821889872, "text": "a"},
        {"start": 11.904727438817131, "end": 12.564989632902787, "text": "sand-bank,"},
        {"start": 12.705045249830048, "end": 13.20524388171312, "text": "underneath"},
        {"start": 13.245259772263767, "end": 13.345299498640381, "text": "the"},
        {"start": 13.445339225016996, "end": 13.705442513596193, "text": "root"},
        {"start": 13.785474294697485, "end": 13.865506075798777, "text": "of"},
        {"start": 13.925529911624745, "end": 13.945537856900067, "text": "a"},
        {"start": 14.16562525492862, "end": 14.525768269884432, "text": "very"},
        {"start": 14.685831832087015, "end": 14.905919230115568, "text": "big"},
        {"start": 15.045974847042828, "end": 15.26606224507138, "text": "fir"},
        {"start": 15.366101971447995, "end": 15.666221150577838, "text": "tree."},
        {"start": 16.126403891910265, "end": 16.28646745411285, "text": "\"Now,"},
        {"start": 16.346491289938818, "end": 16.526562797416723, "text": "my"},
        {"start": 16.666618414343983, "end": 17.006753484024472, "text": "dears,\""},
        {"start": 17.06677731985044, "end": 17.226840882053025, "text": "said"},
        {"start": 17.306872663154316, "end": 17.446928280081575, "text": "old"},
        {"start": 17.486944170632224, "end": 17.787063349762068, "text": "Mrs"},
        {"start": 17.887103076138683, "end": 18.207230200543847, "text": "Rabbit"},
        {"start": 18.347285817471107, "end": 18.487341434398367, "text": "one"},
        {"start": 18.50734937967369, "end": 18.867492394629505, "text": "morning,"},
        {"start": 18.947524175730795, "end": 19.04756390210741, "text": "\"you"},
        {"start": 19.087579792658055, "end": 19.207627464309994, "text": "may"},
        {"start": 19.267651300135963, "end": 19.347683081237253, "text": "go"},
        {"start": 19.487738698164513, "end": 19.66781020564242, "text": "into"},
        {"start": 19.707826096193067, "end": 19.787857877294357, "text": "the"},
        {"start": 19.847881713120326, "end": 20.40810418082937, "text": "fields"},
        {"start": 20.62819157885792, "end": 20.728231305234534, "text": "or"},
        {"start": 20.808263086335828, "end": 21.128390210740992, "text": "down"},
        {"start": 21.168406101291637, "end": 21.24843788239293, "text": "the"},
        {"start": 21.308461718218897, "end": 21.64859678789939, "text": "lane,"},
        {"start": 22.468922544187627, "end": 22.62898610639021, "text": "but"},
        {"start": 22.809057613868116, "end": 23.089168847722636, "text": "don't"},
        {"start": 23.18920857409925, "end": 23.289248300475865, "text": "go"},
        {"start": 23.529343643779743, "end": 23.729423096532972, "text": "into"},
        {"start": 23.829462822909584, "end": 24.14958994731475, "text": "Mr"},
        {"start": 24.169597892590076, "end": 24.74982830557444, "text": "McGregor's"},
        {"start": 24.849868031951054, "end": 25.290042828008158, "text": "garden:"},
        {"start": 25.890281186267845, "end": 26.030336803195105, "text": "your"},
        {"start": 26.110368584296396, "end": 26.47051159925221, "text": "Father"},
        {"start": 26.53053543507818, "end": 26.670591052005438, "text": "had"},
        {"start": 26.710606942556083, "end": 26.770630778382053, "text": "an"},
        {"start": 26.850662559483343, "end": 27.37086913664174, "text": "accident"},
        {"start": 27.43089297246771, "end": 27.690996261046905, "text": "there;"},
        {"start": 27.931091604350783, "end": 28.011123385452073, "text": "he"},
        {"start": 28.091155166553364, "end": 28.251218728755948, "text": "was"},
        {"start": 28.391274345683208, "end": 28.651377634262406, "text": "put"},
        {"start": 28.81144119646499, "end": 28.89147297756628, "text": "in"},
        {"start": 28.931488868116926, "end": 28.95149681339225, "text": "a"},
        {"start": 29.03152859449354, "end": 29.57174311692726, "text": "pie"},
        {"start": 29.671782843303873, "end": 29.811838460231137, "text": "by"},
        {"start": 29.891870241332427, "end": 30.211997365737595, "text": "Mrs"},
        {"start": 30.27202120156356, "end": 30.772219833446634, "text": "McGregor.\""},
        {"start": 31.732601206662135, "end": 31.872656823589395, "text": "\"Now"},
        {"start": 31.97269654996601, "end": 32.13276011216859, "text": "run"},
        {"start": 32.17277600271924, "end": 32.5729349082257, "text": "along,"},
        {"start": 32.61295079877634, "end": 32.692982579877636, "text": "and"},
        {"start": 32.73299847042828, "end": 32.91306997790618, "text": "don't"},
        {"start": 32.95308586845683, "end": 33.093141485384095, "text": "get"},
        {"start": 33.133157375934736, "end": 33.293220938137324, "text": "into"},
        {"start": 33.35324477396329, "end": 33.813427515295714, "text": "mischief."},
        {"start": 34.013506968048944, "end": 34.03351491332427, "text": "I"},
        {"start": 34.07353080387492, "end": 34.15356258497621, "text": "am"},
        {"start": 34.21358642080217, "end": 34.49369765465669, "text": "going"},
        {"start": 34.57372943575799, "end": 34.81382477906186, "text": "out.\""},
        {"start": 35.654158480625426, "end": 35.79421409755268, "text": "Then"},
        {"start": 35.854237933378656, "end": 35.99429355030591, "text": "old"},
        {"start": 36.03430944085656, "end": 36.294412729435756, "text": "Mrs"},
        {"start": 36.35443656526173, "end": 36.63454779911625, "text": "Rabbit"},
        {"start": 36.67456368966689, "end": 36.79461136131883, "text": "took"},
        {"start": 36.83462725186948, "end": 36.8546351971448, "text": "a"},
        {"start": 36.91465903297077, "end": 37.39484971957852, "text": "basket"},
        {"start": 37.47488150067981, "end": 37.554913281781104, "text": "and"},
        {"start": 37.57492122705642, "end": 37.69496889870836, "text": "her"},
        {"start": 37.73498478925901, "end": 38.11513574949014, "text": "umbrella,"},
        {"start": 38.3352231475187, "end": 38.43526287389531, "text": "and"},
        {"start": 38.47527876444595, "end": 38.63534232664854, "text": "went"},
        {"start": 38.67535821719918, "end": 38.895445615227736, "text": "through"},
        {"start": 38.895445615227736, "end": 38.99548534160435, "text": "the"},
        {"start": 39.05550917743032, "end": 39.23558068490823, "text": "wood"},
        {"start": 39.31561246600952, "end": 39.375636301835485, "text": "to"},
        {"start": 39.41565219238613, "end": 39.495683973487424, "text": "the"},
        {"start": 39.51569191876275, "end": 40.035898495921145, "text": "baker's."},
        {"start": 40.77619247110809, "end": 40.85622425220938, "text": "She"},
        {"start": 40.93625603331067, "end": 41.17635137661455, "text": "bought"},
        {"start": 41.19635932188987, "end": 41.2163672671652, "text": "a"},
        {"start": 41.27639110299116, "end": 41.496478501019716, "text": "loaf"},
        {"start": 41.59651822739633, "end": 41.67655000849762, "text": "of"},
        {"start": 41.8366135707002, "end": 42.216764530931336, "text": "brown"},
        {"start": 42.31680425730795, "end": 42.71696316281441, "text": "bread"},
        {"start": 42.91704261556764, "end": 43.0570982324949, "text": "and"},
        {"start": 43.157137958871516, "end": 43.557296864377975, "text": "five"},
        {"start": 43.61732070020394, "end": 43.93744782460911, "text": "currant"},
        {"start": 44.0174796057104, "end": 44.457654401767506, "text": "buns."},
        {"start": 45.418035774983004, "end": 45.89822646159075, "text": "Flopsy,"},
        {"start": 46.01827413324269, "end": 46.438440984024474, "text": "Mopsy,"},
        {"start": 46.518472765125765, "end": 46.6385204367777, "text": "and"},
        {"start": 46.678536327328345, "end": 47.39882235723997, "text": "Cotton-tail,"},
        {"start": 47.47885413834126, "end": 47.57889386471788, "text": "who"},
        {"start": 47.618909755268525, "end": 47.778973317471106, "text": "were"},
        {"start": 47.83899715329708, "end": 47.99906071549966, "text": "good"},
        {"start": 48.03907660605031, "end": 48.259164004078855, "text": "little"},
        {"start": 48.31918783990483, "end": 48.73935469068661, "text": "bunnies,"},
        {"start": 48.8193864717879, "end": 48.999457979265806, "text": "went"},
        {"start": 49.05948181509177, "end": 49.3395930489463, "text": "down"},
        {"start": 49.37960893949694, "end": 49.45964072059823, "text": "the"},
        {"start": 49.5196645564242, "end": 49.839791680829364, "text": "lane"},
        {"start": 49.91982346193066, "end": 49.97984729775663, "text": "to"},
        {"start": 50.039871133582594, "end": 50.380006203263086, "text": "gather"},
        {"start": 50.420022093813735, "end": 51.24034785010197, "text": "blackberries;"},
        {"start": 52.22073716859279, "end": 52.38080073079538, "text": "But"},
        {"start": 52.48084045717199, "end": 52.86099141740313, "text": "Peter,"},
        {"start": 52.94102319850442, "end": 53.04106292488103, "text": "who"},
        {"start": 53.08107881543168, "end": 53.24114237763426, "text": "was"},
        {"start": 53.3611900492862, "end": 53.661309228416044, "text": "very"},
        {"start": 53.821372790618625, "end": 54.14149991502379, "text": "naughty,"},
        {"start": 54.38159525832767, "end": 54.60168265635622, "text": "ran"},
        {"start": 54.74173827328348, "end": 55.10188128823929, "text": "straight"},
        {"start": 55.14189717878994, "end": 55.36198457681849, "text": "away"},
        {"start": 55.42200841264446, "end": 55.50204019374575, "text": "to"},
        {"start": 55.56206402957172, "end": 55.80215937287559, "text": "Mr"},
        {"start": 55.84217526342624, "end": 56.38238978585996, "text": "McGregor's"},
        {"start": 56.462421566961254, "end": 56.862580472467705, "text": "garden,"},
        {"start": 56.982628144119644, "end": 57.10267581577158, "text": "and"},
        {"start": 57.24273143269885, "end": 57.86297773623385, "text": "squeezed"},
        {"start": 57.9029936267845, "end": 58.123081024813054, "text": "under"},
        {"start": 58.163096915363695, "end": 58.24312869646499, "text": "the"},
        {"start": 58.30315253229096, "end": 58.6032717114208, "text": "gate!"}
      ]
    }
  ]
}
